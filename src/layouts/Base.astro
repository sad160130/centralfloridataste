---
import { counties, districts } from '../lib/data.js';
import { countyFilters } from '../lib/manifest.js';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  robots?: string;
}

const SITE_NAME = 'Central Florida Restaurants';

const { title, description, ogType = 'website', ogImage, robots = 'index, follow' } = Astro.props;

const canonical = Astro.props.canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageAbs = ogImage ? new URL(ogImage, Astro.site).href : undefined;

const isHome = Astro.url.pathname === '/';

// Sitewide publisher Organization (E-E-A-T). Referenced by @id from page schemas.
const siteUrl = new URL('/', Astro.site).href;
const ORG_ID = `${siteUrl}#organization`;
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': ORG_ID,
  name: SITE_NAME,
  url: siteUrl,
  logo: new URL('/logo.svg', Astro.site).href,
};

const navCounties = [...counties].sort((a, b) => b.items.length - a.items.length);
const navDistricts = [...districts].sort((a, b) => a.name.localeCompare(b.name));
const navDietary = [...(countyFilters.get('orange') || [])].sort((a, b) => a.label.localeCompare(b.label));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content={robots} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon: the restaurant health-grade "A" placard (site signature) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1e8e3e" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}

    <meta name="twitter:card" content={ogImageAbs ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}

    <!-- Sitewide publisher (E-E-A-T) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <slot name="jsonld" />

    <!-- Fonts: Bricolage Grotesque (display) + Hanken Grotesk (body) + IBM Plex Mono (data) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        color-scheme: light;
        --display: 'Bricolage Grotesque', system-ui, sans-serif;
        --body: 'Hanken Grotesk', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        --mono: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;

        --ground: #fcfbf8;
        --surface: #ffffff;
        --ink: #191815;
        --ink-2: #3f3e38;
        --mute: #67665f;
        --line: #e7e4db;
        --line-strong: #dad6ca;

        --citrus: #f26b1f;        /* brand: wordmark, active, focus, large only */
        --citrus-ink: #c44d0e;    /* small text links / eyebrows (AA on ground) */

        /* Grade hues (heatmap, exactly as briefed) */
        --g-a: #1e8e3e;
        --g-b: #37897f;
        --g-c: #e8a317;
        --g-d: #e2701e;
        --g-f: #c2351b;
        /* Placard solids — A/B nudged darker only so badge text clears AA */
        --ga-solid: #1a8038;
        --gb-solid: #2f7e74;
        --gc-solid: #e8a317;
        --gd-solid: #e2701e;
        --gf-solid: #c2351b;
        /* Card-head washes (~16% grade in ground) */
        --wash-a: #d8eada;
        --wash-b: #dce9e5;
        --wash-c: #f9edd4;
        --wash-d: #f8e5d5;
        --wash-f: #f3dbd5;
        --wash-na: #f1efe9;

        /* ---- Central Florida Taste spec tokens (folded in) ---- */
        /* ground/ink/grade hues/citrus above already match the spec values. */
        --ink-soft:  #4a4740;   /* body copy on ground */
        --ink-mute:  #6e6a60;   /* secondary / supporting text */
        --ink-faint: #9a958a;   /* mono micro-labels, counts */
        --hairline:  #ece7dc;   /* dividers on ground */
        --card-line: #e3ded3;   /* card border (right/bottom) */
        --card-line-hover: #cfc8ba;

        --tangerine:      #f26b1f;   /* = --citrus */
        --tangerine-text: #c44d0e;   /* = --citrus-ink (AA on ground) */

        --font-display: 'Bricolage Grotesque', system-ui, sans-serif;
        --font-body:    'Hanken Grotesk', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        --font-mono:    'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;

        /* spacing scale (4px base) */
        --s1: 4px;  --s2: 8px;  --s3: 12px; --s4: 16px; --s6: 24px;
        --s8: 32px; --s12: 48px; --s16: 64px; --s20: 80px;

        /* radii — squared, civic, signage-like */
        --radius-0: 0px;   /* placard, grade bars — sharp */
        --radius-sm: 2px;  /* cards, chips, panels */
      }

      /* ---- per-grade derived tokens (set [data-grade] on card/placard) ----
         --c grade color · --tint ~10% wash · --ghost ~20% watermark · --deep darkened band */
      [data-grade="A"] { --c: var(--g-a); --tint: #e9f3ec; --ghost: #c9e0cf; --deep: #187534; }
      [data-grade="B"] { --c: var(--g-b); --tint: #ebf2f0; --ghost: #ccdfdb; --deep: #2d7169; }
      [data-grade="C"] { --c: var(--g-c); --tint: #fcf4e2; --ghost: #f4e1b4; --deep: #c2880d; }
      [data-grade="D"] { --c: var(--g-d); --tint: #fbefe3; --ghost: #f2d6bc; --deep: #bc5c18; }
      [data-grade="F"] { --c: var(--g-f); --tint: #f8e7e2; --ghost: #eac2b8; --deep: #a12c16; }
      /* NR / unrated — neutral grey treatment */
      [data-grade="NR"] { --c: #8b877d; --tint: #f1efe9; --ghost: #d8d4ca; --deep: #67645c; }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: var(--body);
        font-size: 1rem;
        line-height: 1.6;
        color: var(--ink);
        background: var(--ground);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a { color: var(--citrus-ink); }

      h1, h2, h3 { font-family: var(--display); color: var(--ink); font-weight: 700; letter-spacing: -0.015em; }
      h1 { font-size: clamp(2rem, 4vw, 3rem); line-height: 1.02; margin: 0 0 0.6rem; }
      h2 { font-size: clamp(1.4rem, 2.4vw, 1.85rem); line-height: 1.08; margin: 2.4rem 0 0.7rem; }
      h3 { font-size: 1.1rem; margin: 0; }

      main { max-width: 1140px; margin: 0 auto; padding: 2rem 1.4rem 3rem; }
      section { margin-top: 1.75rem; }

      .eyebrow { font-family: var(--mono); font-weight: 500; font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--citrus-ink); margin: 0 0 0.9rem; }

      .lead { font-size: 1.15rem; line-height: 1.55; color: var(--ink-2); max-width: 66ch; margin: 1rem 0 0; padding-left: 1rem; border-left: 3px solid var(--citrus); }

      /* ---------- prose (trust pages) ---------- */
      .prose { max-width: 68ch; }
      .prose p { margin: 0 0 1.1rem; }
      .prose h2 { margin: 2rem 0 0.6rem; }
      .prose ul { margin: 0 0 1.1rem; padding-left: 1.2rem; }
      .prose li { margin: 0.35rem 0; }
      .prose strong { font-weight: 700; color: var(--ink); }
      .prose a { color: var(--citrus-ink); font-weight: 500; }
      .trustlinks { margin-top: 2.5rem; padding-top: 1.2rem; border-top: 1px solid var(--line-strong); display: flex; flex-wrap: wrap; gap: 1.4rem; font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.04em; text-transform: uppercase; }
      .trustlinks a { color: var(--citrus-ink); text-decoration: none; }
      .trustlinks a:hover { text-decoration: underline; }

      /* ---------- grade attribution (E-E-A-T) ---------- */
      .attribution { margin: 0 0 1.4rem; padding: 0.85rem 1rem; background: var(--surface); border: 1px solid var(--line); border-left: 4px solid var(--citrus); border-radius: 2px; font-size: 0.88rem; color: var(--ink-2); max-width: 72ch; }
      .attribution p { margin: 0; }
      .attribution a { color: var(--citrus-ink); font-weight: 600; text-decoration: none; }
      .attribution a:hover { text-decoration: underline; }
      .attribution .updated { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--mute); margin-top: 0.45rem; }

      /* ---------- skip ---------- */
      .skip { position: absolute; left: -9999px; top: 0; z-index: 100; background: var(--ink); color: var(--ground); padding: 0.6rem 1rem; }
      .skip:focus { left: 0; }
      #main { outline: none; }

      /* ---------- header ---------- */
      .wrap { max-width: 1220px; margin: 0 auto; padding: 0 1.4rem; }
      .site-header { position: sticky; top: 0; z-index: 50; background: rgba(252, 251, 248, 0.92); backdrop-filter: saturate(140%) blur(8px); border-bottom: 1px solid var(--line-strong); }
      .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; min-height: 64px; position: relative; }
      .brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; color: var(--ink); }
      .brand-mark { width: 34px; height: 34px; border-radius: 2px; flex: 0 0 auto; background: linear-gradient(90deg, var(--g-a) 0 20%, var(--g-b) 20% 40%, var(--g-c) 40% 60%, var(--g-d) 60% 80%, var(--g-f) 80% 100%); box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.12); }
      .brand-text { display: flex; flex-direction: column; line-height: 1.05; }
      .brand-text b { font-family: var(--display); font-weight: 800; font-size: 1.16rem; letter-spacing: -0.02em; color: var(--citrus); }
      .brand-text span { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--mute); margin-top: 2px; }

      .site-nav { display: flex; align-items: center; gap: 0.1rem; }
      .navmenu { position: relative; }
      .navmenu > summary, .navlink { list-style: none; cursor: pointer; font-family: var(--mono); font-weight: 500; font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink); padding: 0.55rem 0.75rem; border-radius: 2px; display: inline-flex; align-items: center; gap: 0.3rem; text-decoration: none; }
      .navmenu > summary::-webkit-details-marker { display: none; }
      .navmenu > summary::after { content: '+'; font-size: 0.85rem; color: var(--mute); }
      .navmenu[open] > summary::after { content: '–'; }
      .navmenu > summary:hover, .navlink:hover { color: var(--citrus-ink); background: #f4f1ea; }
      .navpanel { position: absolute; top: calc(100% + 0.35rem); right: 0; background: var(--surface); border: 1px solid var(--line-strong); border-radius: 2px; box-shadow: 0 18px 44px -18px rgba(25, 24, 21, 0.3); padding: 0.4rem; min-width: 230px; z-index: 60; display: grid; gap: 0.05rem; }
      .navpanel-wide { grid-template-columns: 1fr 1fr; min-width: 400px; }
      .navpanel a { text-decoration: none; color: var(--ink); font-size: 0.88rem; padding: 0.4rem 0.55rem; border-radius: 2px; }
      .navpanel a:hover { background: #f4f1ea; color: var(--citrus-ink); }

      .nav-toggle { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
      .nav-burger { display: none; }

      /* ---------- grade placard (signature object) ----------
         Two-part plaque: bold letter over a darkened mono score band.
         Per-grade --c / --deep come from the [data-grade] token sets above. */
      .placard { width: 48px; height: 48px; flex: none; display: flex; flex-direction: column; border-radius: var(--radius-0); }
      .placard__letter { flex: 1; display: flex; align-items: center; justify-content: center; background: var(--c); color: #fff; font: 800 22px/1 var(--font-display); }
      .placard__score { height: 16px; display: flex; align-items: center; justify-content: center; background: var(--deep); color: #fff; font: 600 10px/1 var(--font-mono); letter-spacing: 0.04em; }
      /* size variants */
      .placard--lg { width: 64px; height: 64px; }
      .placard--lg .placard__letter { font-size: 30px; }
      .placard--lg .placard__score { height: 20px; font-size: 11px; }
      .placard--sm { width: 36px; height: 36px; }
      .placard--sm .placard__letter { font-size: 16px; }
      .placard--sm .placard__score { height: 12px; font-size: 8px; }
      /* AA: the grade-C amber is too light for white — use ink so the C placard
         clears WCAG AA. All other grades keep the spec's white text. */
      [data-grade="C"] .placard__letter, [data-grade="C"] .placard__score { color: var(--ink); }

      /* ---------- restaurant card — HYBRID (grade heatmap) ----------
         White body. Grade rides a 3px top rule + 4px left edge, so a column of
         cards reads as a vertical heatmap. Faint tinted header holds the placard
         + a grade-tinted faded initial. Whole card is one link (no JS). */
      ul.cards { list-style: none; padding: 0; margin: var(--s6) 0; display: grid; gap: var(--s4); grid-template-columns: repeat(4, 1fr); }
      ul.cards > li { display: flex; }

      .card {
        display: flex; flex-direction: column; flex: 1; height: 100%;
        background: #fff; text-decoration: none;
        border: 1px solid var(--card-line);
        border-top: 3px solid var(--c);   /* grade top rule            */
        border-left: 4px solid var(--c);  /* grade left edge → heatmap */
        border-radius: var(--radius-sm);
        transition: transform .14s ease, box-shadow .14s ease,
                    border-right-color .14s ease, border-bottom-color .14s ease;
      }
      .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 22px rgba(25, 24, 21, .10);
        border-right-color: var(--card-line-hover);
        border-bottom-color: var(--card-line-hover);
      }

      .card__head { position: relative; height: 74px; overflow: hidden; background: var(--tint); }
      .card__ghost { position: absolute; right: -4px; bottom: -20px; font: 800 90px/1 var(--font-display); color: var(--ghost); user-select: none; pointer-events: none; }
      .card .placard { position: absolute; left: 13px; top: 13px; }
      .card__gem { position: absolute; right: 9px; top: 9px; display: flex; align-items: center; gap: 4px; background: var(--ink); color: #fff; padding: 4px 7px; font: 500 9px/1 var(--font-mono); letter-spacing: 0.1em; text-transform: uppercase; }
      .card__gem .star { color: var(--g-c); }

      .card__body { flex: 1; display: flex; flex-direction: column; gap: 9px; padding: 13px 14px 14px; }
      .card__name { font: 700 14px/1.2 var(--font-body); letter-spacing: 0.01em; text-transform: uppercase; color: var(--ink); }
      .card:hover .card__name { color: var(--tangerine-text); }
      .card__meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
      .card__rating { font: 600 12px/1 var(--font-mono); color: var(--ink); }
      .card__rating .star { color: var(--g-c); }
      .card__count { font: 400 11px/1 var(--font-mono); color: var(--ink-faint); }
      .card__loc { font: 500 10px/1 var(--font-mono); letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-faint); }
      .card__diet { display: flex; gap: 5px; flex-wrap: wrap; }
      .card__viol { font: 500 11px/1.35 var(--font-mono); color: var(--g-f); }
      .card__date { margin-top: auto; padding-top: 9px; border-top: 1px solid var(--hairline); font: 500 10px/1 var(--font-mono); letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink-faint); }

      /* chips */
      .chip { font: 500 11px/1 var(--font-body); color: var(--ink-soft); background: #f4f0e7; border: 1px solid #e7e1d5; padding: 2px 7px; border-radius: var(--radius-sm); }
      .chip--cuisine { font: 500 10px/1 var(--font-mono); letter-spacing: 0.06em; text-transform: uppercase; color: #5a564d; background: #efeae0; border: 0; padding: 3px 6px; }
      .chip--more { color: var(--ink-faint); background: transparent; border: 0; padding: 2px 5px; }

      @media (max-width: 900px) { ul.cards { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 560px) { ul.cards { grid-template-columns: 1fr; } }

      .badge { display: inline-flex; align-items: center; gap: 0.2rem; vertical-align: middle; font-family: var(--mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink); background: #f3f0e9; border: 1px solid var(--line); padding: 0.1rem 0.42rem; border-radius: 2px; }

      /* ---------- breadcrumb ---------- */
      nav[aria-label='Breadcrumb'] { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--mute); margin: 0 0 1.3rem; }
      nav[aria-label='Breadcrumb'] a { color: var(--ink-2); text-decoration: none; }
      nav[aria-label='Breadcrumb'] a:hover { color: var(--citrus-ink); text-decoration: underline; }

      /* ---------- facts ---------- */
      dl.facts { display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1.4rem; margin: 0.5rem 0 0; font-size: 0.95rem; }
      dl.facts dt { font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--mute); align-self: center; }
      dl.facts dd { margin: 0; color: var(--ink); }

      /* ---------- stat row ---------- */
      .statrow { display: flex; flex-wrap: wrap; gap: 1.5rem 2.5rem; margin: 1.1rem 0 0; padding: 1rem 0; border-top: 1px solid var(--line-strong); border-bottom: 1px solid var(--line-strong); }
      .stat b { font-family: var(--mono); font-weight: 600; font-size: 1.7rem; line-height: 1; display: block; color: var(--ink); }
      .stat span { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mute); margin-top: 0.35rem; display: block; }

      /* ---------- link lists + chips ---------- */
      ul.link-list { columns: 2; column-gap: 1.75rem; list-style: none; padding: 0; margin: 0.85rem 0; }
      ul.link-list li { margin: 0.22rem 0; break-inside: avoid; }
      ul.link-list a { color: var(--citrus-ink); text-decoration: none; font-weight: 500; }
      ul.link-list a:hover { text-decoration: underline; }

      ul.chiplist { list-style: none; padding: 0; margin: 0.85rem 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
      ul.chiplist li { margin: 0; }
      ul.chiplist a { display: inline-flex; align-items: baseline; gap: 0.4rem; text-decoration: none; background: var(--surface); border: 1px solid var(--line-strong); border-radius: 2px; padding: 0.34rem 0.7rem; font-size: 0.86rem; font-weight: 600; color: var(--ink); }
      ul.chiplist a:hover { border-color: var(--citrus); color: var(--citrus-ink); }
      ul.chiplist .ct { font-family: var(--mono); font-weight: 500; color: var(--mute); font-size: 0.74rem; }

      .hub-links { margin: 2.5rem 0 0; padding: 1.1rem 1.2rem; background: var(--surface); border: 1px solid var(--line-strong); border-radius: 2px; font-size: 0.92rem; display: flex; flex-wrap: wrap; gap: 0.4rem 1.2rem; align-items: center; }
      .hub-links strong { font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mute); font-weight: 500; }
      .hub-links a { color: var(--citrus-ink); font-weight: 600; text-decoration: none; }
      .hub-links a:hover { text-decoration: underline; }

      /* ---------- homepage hero + grade distribution ---------- */
      body.is-home { background: radial-gradient(110% 55% at 88% -10%, rgba(242, 107, 31, 0.07), transparent 60%), var(--ground); }

      .hero__eyebrow { display: flex; align-items: center; gap: 14px; margin: 0 0 28px; font: 600 12px/1 var(--font-mono); letter-spacing: 0.16em; text-transform: uppercase; color: var(--tangerine-text); }
      .hero__eyebrow .dot { width: 4px; height: 4px; background: #e0c9a8; display: inline-block; flex: none; }
      .hero__grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: 64px; align-items: start; }
      .hero__title { margin: 0; font: 800 64px/0.98 var(--font-display); letter-spacing: -0.025em; color: var(--ink); }
      .hero__title .accent { color: var(--tangerine); }
      .hero__lede { margin: 28px 0 0; font: 400 19px/1.6 var(--font-body); color: var(--ink-soft); max-width: 30em; }

      /* grade-distribution panel — segments flex-grown by live counts */
      .dist { border: 1px solid var(--card-line); background: #fff; padding: 26px; border-radius: var(--radius-sm); }
      .dist__head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 18px; }
      .dist__title { font: 600 11px/1 var(--font-mono); letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-mute); }
      .dist__n { font: 500 11px/1 var(--font-mono); color: var(--ink-faint); }
      .dist__bar { display: flex; height: 56px; gap: 2px; margin-bottom: 20px; }
      .dist__seg { display: flex; align-items: center; justify-content: center; color: #fff; font: 800 22px/1 var(--font-display); min-width: 0; }
      .dist__seg[data-grade="A"] { background: var(--g-a); }
      .dist__seg[data-grade="B"] { background: var(--g-b); }
      .dist__seg[data-grade="C"] { background: var(--g-c); }
      .dist__seg[data-grade="D"] { background: var(--g-d); }
      .dist__seg[data-grade="F"] { background: var(--g-f); font-size: 18px; }
      .dist__seg[data-grade="C"] { color: var(--ink); }  /* AA on amber */
      .dist__row { display: flex; align-items: center; gap: 12px; padding: 9px 0; border-top: 1px solid var(--hairline); }
      .dist__swatch { width: 14px; height: 14px; flex: none; }
      .dist__letter { width: 16px; font: 800 14px/1 var(--font-display); color: var(--ink); }
      .dist__label { flex: 1; font: 500 13px/1 var(--font-body); color: var(--ink-soft); }
      .dist__range { font: 500 12px/1 var(--font-mono); color: var(--ink-faint); }
      .dist__count { width: 52px; text-align: right; font: 600 12px/1 var(--font-mono); color: var(--ink); }

      @media (max-width: 760px) {
        .hero__grid { grid-template-columns: 1fr; gap: 26px; }
        .hero__title { font-size: 34px; line-height: 1.0; letter-spacing: -0.02em; }
        .hero__lede { font-size: 15px; line-height: 1.55; margin-top: 20px; }
      }

      ul.filtercards { list-style: none; padding: 0; margin: 2rem 0 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.8rem; }
      .filtercard { display: flex; align-items: center; gap: 0.75rem; background: var(--surface); border: 1px solid var(--line-strong); border-radius: 2px; padding: 0.85rem 0.95rem; text-decoration: none; color: var(--ink); transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease; }
      .filtercard:hover { border-color: var(--citrus); box-shadow: 0 14px 28px -18px rgba(25, 24, 21, 0.3); transform: translateY(-2px); }
      .fc-mono { font-family: var(--mono); font-weight: 700; font-size: 1.3rem; width: 2.6rem; height: 2.6rem; border-radius: 2px; display: flex; align-items: center; justify-content: center; background: var(--ink); color: var(--ground); flex: 0 0 auto; }
      .fc-mono.is-a { background: var(--ga-solid); color: #fff; }
      .fc-label b { display: block; font-family: var(--body); font-weight: 600; font-size: 0.95rem; }
      .fc-label span { display: block; font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mute); margin-top: 2px; }

      /* ---------- footer ---------- */
      .site-footer { background: var(--ink); color: #cfcdc6; margin-top: 4rem; }
      .footer-inner { display: grid; grid-template-columns: 1.5fr 0.9fr 0.9fr 0.9fr 1.2fr; gap: 1.75rem 2rem; padding: 3rem 1.4rem; max-width: 1220px; margin: 0 auto; }
      .footer-brand .fb-mark { width: 30px; height: 30px; border-radius: 2px; display: inline-block; vertical-align: middle; background: linear-gradient(90deg, var(--g-a) 0 20%, var(--g-b) 20% 40%, var(--g-c) 40% 60%, var(--g-d) 60% 80%, var(--g-f) 80% 100%); }
      .footer-brand b { font-family: var(--display); font-weight: 800; font-size: 1.3rem; color: var(--citrus); vertical-align: middle; margin-left: 0.45rem; }
      .footer-brand p { font-size: 0.86rem; color: #9b988f; max-width: 36ch; margin: 0.8rem 0 0; line-height: 1.55; }
      .site-footer h4 { font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--citrus); margin: 0 0 0.8rem; font-weight: 500; }
      .footer-links { list-style: none; margin: 0; padding: 0; }
      .footer-links.cols2 { columns: 2; column-gap: 1.25rem; }
      .site-footer a { color: #cfcdc6; text-decoration: none; font-size: 0.87rem; display: block; padding: 0.13rem 0; }
      .site-footer a:hover { color: #fff; text-decoration: underline; }
      .footer-bottom { border-top: 1px solid rgba(255, 255, 255, 0.12); padding: 1.1rem 1.4rem; font-family: var(--mono); font-size: 0.74rem; color: #9b988f; max-width: 1220px; margin: 0 auto; }
      .footer-bottom a { display: inline; color: var(--citrus); text-decoration: none; }
      .footer-bottom a:hover { text-decoration: underline; }

      /* ---------- focus + motion ---------- */
      :focus-visible { outline: 3px solid var(--citrus); outline-offset: 2px; }
      @media (prefers-reduced-motion: no-preference) {
        .is-home .hero__eyebrow { animation: rise 0.5s ease both; }
        .is-home .hero__title { animation: rise 0.5s 0.07s ease both; }
        .is-home .hero__lede { animation: rise 0.5s 0.14s ease both; }
        .is-home .dist { animation: rise 0.5s 0.21s ease both; }
        @keyframes rise { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.001ms !important; animation-iteration-count: 1 !important; transition-duration: 0.001ms !important; scroll-behavior: auto !important; }
      }

      /* ---------- responsive ---------- */
      @media (max-width: 880px) { ul.filtercards { grid-template-columns: 1fr 1fr; } .footer-inner { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 780px) {
        .nav-burger { display: inline-flex; flex-direction: column; gap: 5px; padding: 0.5rem; cursor: pointer; }
        .nav-burger span { width: 22px; height: 2px; background: var(--ink); display: block; transition: transform 0.2s ease, opacity 0.2s ease; }
        .nav-toggle:checked ~ .nav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
        .nav-toggle:checked ~ .nav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
        .site-nav { display: none; position: absolute; left: 0; right: 0; top: 100%; flex-direction: column; align-items: stretch; gap: 0.1rem; background: var(--surface); border-bottom: 1px solid var(--line-strong); box-shadow: 0 18px 34px -20px rgba(25, 24, 21, 0.4); padding: 0.6rem 1rem 1rem; }
        .nav-toggle:checked ~ .site-nav { display: flex; }
        .navmenu { position: static; }
        .navpanel { position: static; box-shadow: none; border: none; padding: 0.15rem 0 0.4rem 0.6rem; min-width: 0; }
        .navpanel-wide { grid-template-columns: 1fr; min-width: 0; }
      }
      @media (max-width: 560px) { ul.link-list { columns: 1; } ul.filtercards { grid-template-columns: 1fr; } .footer-inner { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body class={isHome ? 'is-home' : ''}>
    <a class="skip" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="wrap header-inner">
        <a href="/" class="brand" aria-label={`${SITE_NAME} home`}>
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-text"><b>Central Florida</b><span>Restaurant Grades</span></span>
        </a>

        <input type="checkbox" id="navtoggle" class="nav-toggle" aria-hidden="true" tabindex="-1" />
        <label for="navtoggle" class="nav-burger" aria-label="Toggle menu"><span></span><span></span><span></span></label>

        <nav class="site-nav" aria-label="Primary">
          <details class="navmenu">
            <summary>Counties</summary>
            <div class="navpanel">
              {navCounties.map((c) => <a href={`/${c.slug}-county/`}>{c.name} County</a>)}
            </div>
          </details>
          <details class="navmenu">
            <summary>Districts</summary>
            <div class="navpanel navpanel-wide">
              {navDistricts.map((d) => <a href={`/neighborhood/${d.slug}/`}>{d.name}</a>)}
            </div>
          </details>
          <details class="navmenu">
            <summary>Dietary</summary>
            <div class="navpanel navpanel-wide">
              {navDietary.map((p) => <a href={`${p.url}/`}>{p.label}</a>)}
            </div>
          </details>
          <a class="navlink" href="/data-sources/">Data</a>
        </nav>
      </div>
    </header>

    <div id="main" tabindex="-1">
      <slot />
    </div>

    <footer class="site-footer" id="data-source">
      <div class="footer-inner">
        <div class="footer-brand">
          <p><span class="fb-mark" aria-hidden="true"></span><b>Central Florida Restaurants</b></p>
          <p>
            Restaurant health inspection grades, dietary options, and diner ratings across Central
            Florida. Inspection data from Florida DBPR public records.
          </p>
        </div>
        <div>
          <h4>About this data</h4>
          <ul class="footer-links">
            <li><a href="/methodology/">Methodology</a></li>
            <li><a href="/data-sources/">Data &amp; sources</a></li>
            <li><a href="/about/">About</a></li>
          </ul>
        </div>
        <div>
          <h4>Counties</h4>
          <ul class="footer-links">
            {navCounties.map((c) => <li><a href={`/${c.slug}-county/`}>{c.name} County</a></li>)}
          </ul>
        </div>
        <div>
          <h4>Dietary</h4>
          <ul class="footer-links">
            {navDietary.map((p) => <li><a href={`${p.url}/`}>{p.label}</a></li>)}
          </ul>
        </div>
        <div>
          <h4>Neighborhoods</h4>
          <ul class="footer-links cols2">
            {navDistricts.map((d) => <li><a href={`/neighborhood/${d.slug}/`}>{d.name}</a></li>)}
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        © 2026 Central Florida Restaurants · Inspection data: Florida Department of Business and
        Professional Regulation (DBPR) public records. · <a href="/sitemap-index.xml">Sitemap</a>
      </div>
    </footer>
  </body>
</html>
