---
import Base from '../../../layouts/Base.astro';
import GradeBadge from '../../../components/GradeBadge.astro';
import GradeAttribution from '../../../components/GradeAttribution.astro';
import SaferNearby from '../../../components/SaferNearby.astro';
import restaurants from '../../../data/restaurants.json';
import { cityHubSlugs, districtHubSlugs } from '../../../lib/data.js';
import { titleCase, formatDate, listJoin } from '../../../lib/format.js';
import { listingProse } from '../../../lib/prose.js';
import { photoInfo } from '../../../lib/photos.js';
import { reviewInfo } from '../../../lib/reviews.js';
import { compositeScore } from '../../../lib/score.js';

// One static page per restaurant — only published === true rows are emitted.
export function getStaticPaths() {
  return restaurants
    .filter((r) => r.published === true)
    .map((r) => ({
      params: { city_slug: r.city_slug, slug: r.slug },
      props: { r },
    }));
}

const { r } = Astro.props;

// Storefront photo (Places) when available; attribution is mandatory under
// Google's terms and rendered in the figcaption below the image.
const photo = photoInfo(r.license_key);

// Scraped Google reviews (text/stars/date only — no reviewer PII in the source).
// null when this restaurant has none, so the review excerpts are omitted.
const reviews = reviewInfo(r.license_key);

/* ---------- derived display values ---------- */
const cityDisplay = titleCase(r.city);
const cuisineDisplay = r.cuisine ? titleCase(r.cuisine) : null;
const dietaryDisplay = Array.isArray(r.dietary)
  ? r.dietary.map((x) => String(x).replace(/_/g, '-'))
  : [];
const hasRating =
  Number.isFinite(r.rating) && Number.isFinite(r.reviews_count) && r.reviews_count > 0;

/* ---------- community rating (Google) + composite Overall Score ---------- */
// Headline rating: Google's full rating/count when present (large sample),
// else the scraped average so the card never shows a null. The same average
// feeds the composite so the two can't disagree.
const communityAvg = hasRating
  ? r.rating
  : reviews && Number.isFinite(reviews.avgStars)
    ? reviews.avgStars
    : null;
const communityCount = hasRating
  ? r.reviews_count
  : reviews
    ? reviews.count
    : null;
const hasCommunity = Number.isFinite(communityAvg);
const communityStars = hasCommunity ? Math.round(communityAvg) : 0;
const score = compositeScore(r, { avgStars: communityAvg });

const inspectionDate = formatDate(r.latest_inspection_date);
const totalViolations =
  (r.hp_violations || 0) + (r.intermediate_violations || 0) + (r.basic_violations || 0);

// Internal-link guards: only link to hubs that were actually generated.
const cityHasHub = cityHubSlugs.has(r.city_slug);
const districtHasHub = !!r.district_slug && districtHubSlugs.has(r.district_slug);

/* ---------- enriched fields (inspection history, contact, nearby) ---------- */
const history = Array.isArray(r.inspection_history)
  ? [...r.inspection_history].sort((a, b) => String(b.date).localeCompare(String(a.date)))
  : [];
const daysSince = Number.isFinite(r.days_since_inspection) ? r.days_since_inspection : null;
const pct = Number.isFinite(r.health_percentile) ? r.health_percentile : null;
const hours = Array.isArray(r.opening_hours) ? r.opening_hours : [];
const phoneDigits = r.phone ? String(r.phone).replace(/\D/g, '') : null;
const telHref = phoneDigits
  ? `+${phoneDigits.length === 10 ? '1' + phoneDigits : phoneDigits}`
  : null;

// Only link to nearby restaurants whose detail page actually exists (published).
const p1Urls = new Set();
for (const x of restaurants) if (x.published === true) p1Urls.add(x.url);
const nearby = Array.isArray(r.nearby_safer) ? r.nearby_safer : [];
const showNearby = r.health_grade !== 'A' && nearby.length > 0;

/* ---------- distinctive, data-driven prose (see lib/prose.js) ----------
   Opens with the single most notable TRUE fact about this restaurant and
   rotates phrasing/structure by its data, so no two pages read alike. */
const prose = listingProse(r, {
  latestDisposition: history[0]?.disposition ?? null,
  hasSafer: showNearby,
});

/* ---------- SEO title + description ---------- */
// Keep titles unique: same-name chains in the same city would otherwise collide,
// so disambiguate those with the street address (title metadata only).
const titleBaseOf = (x) =>
  (`${x.name} — ${titleCase(x.city)}, FL` + (x.health_grade ? ` (Grade ${x.health_grade})` : '')).slice(0, 60);
const titleCounts = new Map();
for (const x of restaurants) {
  if (x.phase !== 1) continue;
  const t = titleBaseOf(x);
  titleCounts.set(t, (titleCounts.get(t) || 0) + 1);
}
const baseTitle = titleBaseOf(r);
const seoTitle =
  titleCounts.get(baseTitle) > 1 && r.address
    ? `${r.name}, ${r.address} — ${cityDisplay}, FL`.slice(0, 60)
    : baseTitle;

const seoDescription = [
  `${r.name} in ${cityDisplay}, FL.`,
  r.health_grade
    ? `Health grade ${r.health_grade}${Number.isFinite(r.health_score) ? ` (${r.health_score}/100)` : ''}.`
    : '',
  cuisineDisplay ? `${cuisineDisplay} cuisine.` : '',
  hasRating ? `${r.rating}★ from ${r.reviews_count} reviews.` : '',
].filter(Boolean).join(' ').slice(0, 155);

/* ---------- JSON-LD: Restaurant + BreadcrumbList ---------- */
const pageUrl = new URL(r.url + '/', Astro.site).href;
const orgId = `${new URL('/', Astro.site).href}#organization`;

// Latest inspection (incl. cited violations) as structured additionalProperty.
const latest = history[0];
const inspectionProps = [];
if (latest) {
  inspectionProps.push({ '@type': 'PropertyValue', name: 'Latest health inspection date', value: latest.date });
  if (latest.disposition)
    inspectionProps.push({ '@type': 'PropertyValue', name: 'Inspection disposition', value: latest.disposition });
  inspectionProps.push({ '@type': 'PropertyValue', name: 'High-priority violations', value: latest.high ?? 0 });
  inspectionProps.push({ '@type': 'PropertyValue', name: 'Intermediate violations', value: latest.intermediate ?? 0 });
  inspectionProps.push({ '@type': 'PropertyValue', name: 'Basic violations', value: latest.basic ?? 0 });
  for (const v of latest.violations || [])
    inspectionProps.push({ '@type': 'PropertyValue', name: `Violation ${v.code}: ${v.description}`, value: v.count });
}

const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: r.name,
  url: pageUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: r.address || undefined,
    addressLocality: cityDisplay,
    addressRegion: 'FL',
    addressCountry: 'US',
  },
  geo:
    Number.isFinite(r.lat) && Number.isFinite(r.lng)
      ? { '@type': 'GeoCoordinates', latitude: r.lat, longitude: r.lng }
      : undefined,
  servesCuisine: cuisineDisplay || undefined,
  priceRange: r.price_level || undefined,
  telephone: r.phone || undefined,
  hasMap: r.google_maps_url || undefined,
  aggregateRating: hasRating
    ? {
        '@type': 'AggregateRating',
        ratingValue: r.rating,
        reviewCount: r.reviews_count,
        bestRating: 5,
        worstRating: 1,
      }
    : undefined,
  additionalProperty: inspectionProps.length ? inspectionProps : undefined,
  publisher: { '@id': orgId },
  dateModified: r.latest_inspection_date || undefined,
};

const crumbs = [
  { name: 'Home', item: new URL('/', Astro.site).href },
  { name: `${r.county} County`, item: new URL(`/${r.county_slug}-county/`, Astro.site).href },
];
if (cityHasHub) {
  crumbs.push({ name: cityDisplay, item: new URL(`/${r.city_slug}/`, Astro.site).href });
} else {
  crumbs.push({ name: cityDisplay });
}
crumbs.push({ name: r.name, item: pageUrl });

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    ...(c.item ? { item: c.item } : {}),
  })),
};
---

<Base title={seoTitle} description={seoDescription} ogType="article">
  <script
    type="application/ld+json"
    slot="jsonld"
    set:html={JSON.stringify([restaurantSchema, breadcrumbSchema])}
  />

  <main>
    <nav aria-label="Breadcrumb">
      <a href="/">Home</a> &rsaquo;
      <a href={`/${r.county_slug}-county/`}>{r.county} County</a> &rsaquo;
      {cityHasHub ? <a href={`/${r.city_slug}/`}>{cityDisplay}</a> : <span>{cityDisplay}</span>} &rsaquo;
      <span>{r.name}</span>
    </nav>

    <article>
      {photo && (
        <figure class="detail-photo">
          <img src={photo.src} alt={`Photo of ${r.name}`} loading="eager" fetchpriority="high" decoding="async" width="800" height="450" />
          <figcaption set:html={`Photo: ${photo.attribution.length ? photo.attribution.join(' · ') : 'via Google'}`} />
        </figure>
      )}

      <div class="detail-head">
        <GradeBadge grade={r.health_grade} score={r.health_score} size="lg" />
        <h1>
          {r.name}
          {r.hidden_gem && <span class="badge">★ Hidden gem</span>}
        </h1>
      </div>

      <GradeAttribution updated={inspectionDate || 'June 2026'} />

      {prose.callout && (
        <p class={`signal signal--${prose.callout.kind}`}>{prose.callout.text}</p>
      )}

      {prose.format === 'qa' ? (
        <p class="lead-prose"><strong>{prose.qa.q}</strong> {prose.qa.a}</p>
      ) : prose.format === 'table' ? (
        <dl class="quickfacts">
          {prose.quickfacts.map((f) => (<><dt>{f.k}</dt><dd>{f.v}</dd></>))}
        </dl>
      ) : (
        <p class="lead-prose">{prose.lead}</p>
      )}
      {prose.support && <p>{prose.support}</p>}

      {(r.directions_url || telHref) && (
        <p class="actions">
          {r.directions_url && (
            <a class="btn" href={r.directions_url} target="_blank" rel="noopener">Get directions</a>
          )}
          {telHref && <a class="btn btn-alt" href={`tel:${telHref}`}>Call {r.phone}</a>}
        </p>
      )}

      {/* Risky kitchens surface safer alternatives up front; clean ones don't need to. */}
      {prose.promoteSafer && showNearby && <SaferNearby r={r} nearby={nearby} p1Urls={p1Urls} />}

      <section>
        <h2>Restaurant details</h2>
        <dl class="facts">
          {r.health_grade && (
            <>
              <dt>Health grade</dt>
              <dd>
                {r.health_grade}
                {Number.isFinite(r.health_score) && ` (${r.health_score}/100)`}
              </dd>
            </>
          )}
          {r.health_grade && (
            <>
              <dt>Violations</dt>
              <dd>
                {totalViolations === 0
                  ? 'None recorded'
                  : `${totalViolations} total — ` +
                    [
                      r.hp_violations ? `${r.hp_violations} high-priority` : null,
                      r.intermediate_violations ? `${r.intermediate_violations} intermediate` : null,
                      r.basic_violations ? `${r.basic_violations} basic` : null,
                    ]
                      .filter(Boolean)
                      .join(', ')}
              </dd>
            </>
          )}
          {r.address && (
            <>
              <dt>Address</dt>
              <dd>{r.address}, {cityDisplay}, FL</dd>
            </>
          )}
          {cuisineDisplay && (
            <>
              <dt>Cuisine</dt>
              <dd>{cuisineDisplay}</dd>
            </>
          )}
          {Array.isArray(r.categories) && r.categories.length > 0 && (
            <>
              <dt>Categories</dt>
              <dd>{r.categories.join(', ')}</dd>
            </>
          )}
          {r.price_level && (
            <>
              <dt>Price</dt>
              <dd>{r.price_level}</dd>
            </>
          )}
          {hasRating && (
            <>
              <dt>Rating</dt>
              <dd>{r.rating} stars ({r.reviews_count} reviews)</dd>
            </>
          )}
          {r.neighborhood && (
            <>
              <dt>Neighborhood</dt>
              <dd>{r.neighborhood}</dd>
            </>
          )}
          {r.seats && Number(r.seats) > 0 && (
            <>
              <dt>Seats</dt>
              <dd>{r.seats}</dd>
            </>
          )}
          {r.phone && (
            <>
              <dt>Phone</dt>
              <dd><a href={`tel:${telHref}`}>{r.phone}</a></dd>
            </>
          )}
          {r.website && (
            <>
              <dt>Website</dt>
              <dd>
                <a href={r.website} rel="nofollow noopener" target="_blank">
                  Official website
                </a>
              </dd>
            </>
          )}
        </dl>
      </section>

      {hasCommunity && (
        <section class="community" aria-labelledby="community-h">
          <div class="dr-head">
            <h2 id="community-h">Community Rating</h2>
            <span class="dr-source">Reviews via Google</span>
          </div>
          <div class="comm-card">
            <div class="comm-score">
              <span class="comm-avg">{communityAvg.toFixed(1)}</span>
              <span class="comm-stars" aria-hidden="true">{'★'.repeat(communityStars)}{'☆'.repeat(5 - communityStars)}</span>
              <span class="comm-label">Community-sourced rating</span>
              {Number.isFinite(communityCount) && (
                <span class="comm-count">{communityCount.toLocaleString('en-US')} review{communityCount === 1 ? '' : 's'}</span>
              )}
            </div>
            {r.google_maps_url && (
              <a class="comm-link" href={r.google_maps_url} target="_blank" rel="nofollow noopener">
                Read all reviews on Google &rarr;
              </a>
            )}
          </div>
          {reviews && (
            <ul class="dr-list">
              {reviews.items.slice(0, 3).map((rv) => (
                <li class="dr-card">
                  <div class="dr-meta">
                    {rv.stars != null && (
                      <span class="dr-stars" aria-label={`Rated ${rv.stars} out of 5 stars`}>
                        <span aria-hidden="true">{'★'.repeat(rv.stars)}{'☆'.repeat(5 - rv.stars)}</span>
                      </span>
                    )}
                    {rv.date && <span class="dr-date">{formatDate(rv.date) || rv.date}</span>}
                  </div>
                  <p class="dr-text">{rv.excerpt}</p>
                </li>
              ))}
            </ul>
          )}
        </section>
      )}

      <section class="overall" aria-labelledby="overall-h">
        <h2 id="overall-h">Overall Score</h2>
        <div class="score-card">
          <div class="score-total">
            <p class="score-total-num">
              <span class="score-num">{score.total}</span>
              <span class="score-den">/ {score.denominator}</span>
            </p>
            <div class="score-track score-track-lg" aria-hidden="true">
              <div class="score-fill score-fill-total" style={`width:${Math.round((score.total / score.denominator) * 100)}%`}></div>
            </div>
          </div>
          <ul class="score-bars">
            {score.components.map((c) => (
              <li class="score-row">
                <div class="score-rowhead">
                  <span class="score-clabel">{c.label}</span>
                  <span class="score-cval">{c.score}<span class="score-cmax">/{c.max}</span></span>
                </div>
                <div class="score-track" aria-hidden="true">
                  <div class="score-fill" style={`width:${Math.round((c.score / c.max) * 100)}%`}></div>
                </div>
                <span class="score-cdetail">{c.detail}</span>
              </li>
            ))}
          </ul>
        </div>
        <p class="overall-note">
          Composite score from health grade, dietary options, ratings, and inspection record &mdash; distinct from the state-derived health grade.
        </p>
      </section>

      {hours.length > 0 && (
        <section>
          <h2>Opening hours</h2>
          <dl class="hours">
            {hours.map((h) => (
              <>
                <dt>{h.day}</dt>
                <dd>{h.hours}</dd>
              </>
            ))}
          </dl>
        </section>
      )}

      {history.length > 0 && (
        <section>
          <h2>Inspection history</h2>
          <p class="src">
            The following records are from Florida DBPR public inspection records, most recent first.
          </p>
          <ol class="timeline">
            {history.map((v) => (
              <li class="visit">
                <p class="visit-head">
                  <strong>{formatDate(v.date) || v.date}</strong>
                  {v.type && <span> · {v.type}</span>}
                </p>
                {v.disposition && <p class="visit-disp">{v.disposition}</p>}
                <p class="visit-counts">
                  {v.high || 0} high-priority · {v.intermediate || 0} intermediate · {v.basic || 0} basic
                </p>
                {Array.isArray(v.violations) && v.violations.length > 0 ? (
                  <ul class="viol-list">
                    {v.violations.map((vi) => (
                      <li>{vi.code} — {vi.description}{vi.count > 1 ? ` (×${vi.count})` : ''}</li>
                    ))}
                  </ul>
                ) : (
                  <p class="viol-none">No violations cited.</p>
                )}
              </li>
            ))}
          </ol>
        </section>
      )}

      {showNearby && !prose.promoteSafer && <SaferNearby r={r} nearby={nearby} p1Urls={p1Urls} />}

      <nav class="hub-links" aria-label="Explore more">
        <strong>Explore more:</strong>
        <a href={`/${r.county_slug}-county/`}>{r.county} County</a>
        {cityHasHub && <a href={`/${r.city_slug}/`}>{cityDisplay}</a>}
        {districtHasHub && <a href={`/neighborhood/${r.district_slug}/`}>{r.district}</a>}
      </nav>
    </article>
  </main>

  <style>
    .detail-photo { margin: 0 0 1.3rem; }
    .detail-photo img { width: 100%; height: auto; aspect-ratio: 16 / 9; max-height: 380px; object-fit: cover; display: block; border: 1px solid var(--line-strong); border-radius: 2px; background: var(--line); }
    .detail-photo figcaption { margin-top: 0.35rem; font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.04em; color: var(--mute); }
    .detail-photo figcaption a { color: var(--mute); text-decoration: underline; }
    .detail-photo figcaption a:hover { color: var(--citrus-ink); }
    .detail-head { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; margin: 0 0 0.6rem; }
    .detail-head h1 { margin: 0; }
    .detail-head h1 .badge { margin-left: 0.5rem; }
    /* table-format lead — a tight verdict card */
    dl.quickfacts { margin: 0 0 1.2rem; max-width: 30rem; border: 1px solid var(--line-strong); border-left: 4px solid var(--citrus); border-radius: 2px; display: grid; grid-template-columns: max-content 1fr; }
    dl.quickfacts dt { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--mute); padding: 0.5rem 0.9rem; border-bottom: 1px solid var(--line); align-self: center; }
    dl.quickfacts dd { margin: 0; font-weight: 600; color: var(--ink); padding: 0.5rem 0.9rem; border-bottom: 1px solid var(--line); }
    dl.quickfacts dt:last-of-type, dl.quickfacts dd:last-of-type { border-bottom: 0; }
    .lead-prose strong { color: var(--ink); }
    .actions { display: flex; flex-wrap: wrap; gap: 0.6rem; margin: 0 0 1.6rem; }
    .btn {
      display: inline-block; background: var(--citrus); color: var(--ink); text-decoration: none;
      padding: 0.6rem 1.1rem; border-radius: 2px; font-size: 0.86rem; font-weight: 700;
      font-family: var(--body); transition: filter 0.15s ease;
    }
    .btn:hover { filter: brightness(0.95); }
    .btn-alt { background: transparent; color: var(--ink); box-shadow: inset 0 0 0 1.5px var(--ink); }
    .btn-alt:hover { background: #f3f0e9; }
    dl.hours { display: grid; grid-template-columns: max-content 1fr; gap: 0.3rem 1.5rem; margin: 0; font-size: 0.92rem; }
    dl.hours dt { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--mute); }
    dl.hours dd { margin: 0; }
    .src { font-size: 0.84rem; color: var(--mute); font-style: italic; margin: 0.3rem 0 0; }

    /* inspection history — squared report timeline */
    ol.timeline { list-style: none; padding: 0; margin: 1.25rem 0 0; display: grid; gap: 1rem; }
    .visit {
      position: relative; padding: 1rem 1.15rem; background: var(--surface);
      border: 1px solid var(--line); border-left: 4px solid var(--ink); border-radius: 2px;
    }
    .visit-head { margin: 0; font-family: var(--mono); font-weight: 600; font-size: 0.96rem; }
    .visit-head span { font-family: var(--body); font-weight: 400; font-size: 0.82rem; color: var(--mute); }
    .visit-disp { margin: 0.25rem 0; color: var(--ink-2); font-size: 0.9rem; }
    .visit-counts { margin: 0.3rem 0 0; font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--mute); }
    ul.viol-list { margin: 0.55rem 0 0; padding-left: 1.1rem; font-size: 0.88rem; color: var(--ink-2); }
    ul.viol-list li { margin: 0.18rem 0; }
    ul.viol-list li::marker { color: var(--mute); }
    .viol-none { font-family: var(--mono); font-size: 0.82rem; color: var(--g-a); margin: 0.3rem 0 0; }

    /* community rating + review excerpts (Google reviews, no PII) */
    .dr-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.6rem 1rem; flex-wrap: wrap; }
    .dr-head h2 { margin: 0; }
    .dr-source { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--mute); white-space: nowrap; }
    .comm-card { margin: 1rem 0 0; padding: 1.1rem 1.25rem; background: var(--surface); border: 1px solid var(--line-strong); border-left: 4px solid var(--citrus); border-radius: 2px; display: flex; align-items: center; justify-content: space-between; gap: 1rem 1.5rem; flex-wrap: wrap; }
    .comm-score { display: grid; grid-template-columns: auto auto; align-items: baseline; column-gap: 0.7rem; row-gap: 0.15rem; }
    .comm-avg { grid-row: 1 / span 2; font-family: var(--mono); font-size: 2.9rem; font-weight: 700; line-height: 0.9; color: var(--ink); }
    .comm-stars { font-family: var(--mono); font-size: 1.05rem; letter-spacing: 0.12em; color: var(--citrus); line-height: 1; }
    .comm-label { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--mute); }
    .comm-count { grid-column: 2; font-size: 0.82rem; color: var(--ink-2); }
    .comm-link { font-family: var(--body); font-size: 0.86rem; font-weight: 700; color: var(--citrus-ink); text-decoration: none; white-space: nowrap; }
    .comm-link:hover { text-decoration: underline; }
    ul.dr-list { list-style: none; padding: 0; margin: 0.9rem 0 0; display: grid; gap: 0.9rem; }
    .dr-card { padding: 0.95rem 1.1rem; background: var(--surface); border: 1px solid var(--line); border-left: 4px solid var(--citrus); border-radius: 2px; }
    .dr-meta { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; flex-wrap: wrap; }
    .dr-stars { font-family: var(--mono); font-size: 0.95rem; letter-spacing: 0.14em; color: var(--citrus); line-height: 1; }
    .dr-date { font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--mute); }
