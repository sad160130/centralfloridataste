---
import Base from '../layouts/Base.astro';
import RestaurantCard from '../components/RestaurantCard.astro';
import restaurants from '../data/restaurants.json';
import { counties, districts, phase1 } from '../lib/data.js';
import { specialPages } from '../lib/manifest.js';

const totalTracked = restaurants.length;

const countyList = [...counties].sort((a, b) => b.items.length - a.items.length);
const districtList = [...districts].sort((a, b) => b.items.length - a.items.length);
const totalAGrade = phase1.filter((r) => r.health_grade === 'A').length;

// Live grade distribution across published restaurants — drives the hero panel.
const GRADES = [
  { g: 'A', label: 'Excellent', range: '90–100' },
  { g: 'B', label: 'Good', range: '80–89' },
  { g: 'C', label: 'Fair', range: '70–79' },
  { g: 'D', label: 'Poor', range: '60–69' },
  { g: 'F', label: 'Failing', range: '<60' },
];
const gradeCounts = { A: 0, B: 0, C: 0, D: 0, F: 0 };
for (const r of phase1) {
  const g = String(r.health_grade).toUpperCase();
  if (g in gradeCounts) gradeCounts[g] += 1;
}
const distTotal = GRADES.reduce((s, { g }) => s + gradeCounts[g], 0);

// Featured: every hidden gem, then the most-reviewed A-grade spots to fill out the row.
const hiddenGems = phase1.filter((r) => r.hidden_gem);
const topA = phase1
  .filter((r) => r.health_grade === 'A' && Number.isFinite(r.reviews_count))
  .sort((a, b) => b.reviews_count - a.reviews_count);
const featured = [...hiddenGems, ...topA.filter((r) => !hiddenGems.includes(r))].slice(0, 8);

// A few "Top-Rated & Safe" city guides for the homepage (largest first).
// (Hidden-gems guides have no phase-1 data yet; they appear in later phases.)
const topRatedGuides = specialPages
  .filter((p) => p.specialType === 'top_rated_safe')
  .sort((a, b) => b.items.length - a.items.length)
  .slice(0, 8);

const siteUrl = new URL('/', Astro.site).href;
const seoTitle = 'Central Florida Restaurants: Health Grades & Guide';
const seoDescription =
  'Browse Central Florida restaurants by official health inspection grade (A–F), dietary ' +
  'options, and diner ratings — find clean, safe places to eat.';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Central Florida Restaurants',
  url: siteUrl,
  description: seoDescription,
  publisher: { '@id': `${siteUrl}#organization` },
};
// Organization is emitted sitewide by Base.astro (publisher, with @id + logo).

// FAQ — targets "florida restaurants" intent + answer-engine (FAQPage) visibility.
const faqs = [
  {
    q: 'Does Florida give restaurants letter grades or scores?',
    a: "No. Florida's Department of Business and Professional Regulation (DBPR) inspects restaurants and records violations, but it does not assign letter grades or scores. The A–F grades on this site are calculated by us from DBPR's public inspection records.",
  },
  {
    q: 'How are the health grades for Florida restaurants calculated?',
    a: 'Each restaurant starts at 100 points; we subtract 8 points per high-priority violation, 3 per intermediate, and 1 per basic from its most recent inspection, plus penalties for enforcement actions. Scores map to A (90+), B (80–89), C (70–79), D (60–69), and F (below 60).',
  },
  {
    q: 'Which Florida restaurants does this guide cover?',
    a: `We cover the eight Central Florida counties in DBPR District 4 — Orange, Brevard, Volusia, Seminole, Osceola, Lake, St. Lucie, and Indian River — currently ${phase1.length} graded restaurants, with more added every week.`,
  },
  {
    q: 'How current is the inspection data?',
    a: 'We refresh from DBPR on a regular cycle, and every restaurant page shows the date its data was last updated.',
  },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base title={seoTitle} description={seoDescription}>
  <script
    type="application/ld+json"
    slot="jsonld"
    set:html={JSON.stringify([websiteSchema, faqSchema])}
  />

  <main>
    <section class="hero__body">
      <p class="hero__eyebrow"><span class="dot" aria-hidden="true"></span>DBPR-graded · {totalTracked.toLocaleString('en-US')} restaurants · Updated June 2026</p>
      <div class="hero__grid">
        <div class="hero__intro">
          <h1 class="hero__title">Central Florida Restaurants, Graded <span class="accent">A–F</span> by Health Inspection</h1>
          <p class="hero__lede">
            Compare Central Florida restaurants by the one thing Florida won&rsquo;t tell you: how clean
            they are. We turn the state&rsquo;s public DBPR inspection records into clear A–F health grades
            for {phase1.length} restaurants &mdash; {totalAGrade} currently grade A &mdash; alongside
            dietary options and diner ratings. Browse by county, city, or one of the region&rsquo;s named
            dining districts.
          </p>
        </div>

        <aside class="dist" aria-label="Health grade distribution across published restaurants">
          <div class="dist__head">
            <span class="dist__title">Grade distribution</span>
            <span class="dist__n">{distTotal.toLocaleString('en-US')} graded</span>
          </div>
          <div class="dist__bar" aria-hidden="true">
            {GRADES.map(({ g }) => gradeCounts[g] > 0 && (
              <div class="dist__seg" data-grade={g} style={`flex:${gradeCounts[g]}`}>{g}</div>
            ))}
          </div>
          {GRADES.map(({ g, label, range }) => (
            <div class="dist__row">
              <span class="dist__swatch" style={`background: var(--g-${g.toLowerCase()})`} aria-hidden="true"></span>
              <span class="dist__letter">{g}</span>
              <span class="dist__label">{label}</span>
              <span class="dist__range">{range}</span>
              <span class="dist__count">{gradeCounts[g].toLocaleString('en-US')}</span>
            </div>
          ))}
        </aside>
      </div>
    </section>

    <article>
      <ul class="filtercards">
        <li><a class="filtercard" href="#favorites">
          <span class="fc-mono is-a" aria-hidden="true">A</span>
          <span class="fc-label"><b>Top-rated &amp; safe</b><span>Grade-A guides</span></span>
        </a></li>
        <li><a class="filtercard" href="#featured">
          <span class="fc-mono" aria-hidden="true">✦</span>
          <span class="fc-label"><b>Featured picks</b><span>Hidden gems</span></span>
        </a></li>
        <li><a class="filtercard" href="#counties">
          <span class="fc-mono" aria-hidden="true">C</span>
          <span class="fc-label"><b>Browse by county</b><span>8 counties</span></span>
        </a></li>
        <li><a class="filtercard" href="#districts">
          <span class="fc-mono" aria-hidden="true">N</span>
          <span class="fc-label"><b>Neighborhoods</b><span>Dining districts</span></span>
        </a></li>
      </ul>

      <section id="counties">
        <h2>Browse by county</h2>
        <ul class="chiplist">
          {countyList.map((c) => (
            <li>
              <a href={`/${c.slug}-county/`}>{c.name} County <span class="ct">{c.items.length}</span></a>
            </li>
          ))}
        </ul>
      </section>

      <section id="districts">
        <h2>Dining districts &amp; neighborhoods</h2>
        <ul class="chiplist">
          {districtList.map((d) => (
            <li>
              <a href={`/neighborhood/${d.slug}/`}>{d.name} <span class="ct">{d.items.length}</span></a>
            </li>
          ))}
        </ul>
      </section>

      {topRatedGuides.length > 0 && (
        <section id="favorites">
          <h2>Health &amp; local favorites</h2>
          <ul class="link-list">
            {topRatedGuides.map((p) => (
              <li><a href={`${p.url}/`}>Top-Rated, Health-Safe Restaurants in {p.geoName}</a> ({p.items.length})</li>
            ))}
          </ul>
        </section>
      )}

      <section id="featured">
        <h2>Featured restaurants</h2>
        <ul class="cards">
          {featured.map((r) => <RestaurantCard r={r} />)}
        </ul>
      </section>

      <section id="faq">
        <h2>Frequently asked questions about Florida restaurant grades</h2>
        <div class="prose">
          {faqs.map((f) => (
            <>
              <h3>{f.q}</h3>
              <p>{f.a}</p>
            </>
          ))}
          <p>Read the full method on our <a href="/methodology/">methodology page</a>.</p>
        </div>
      </section>
    </article>
  </main>
</Base>
