---
import Base from '../layouts/Base.astro';
import { counties } from '../lib/data.js';

const countyList = [...counties].sort((a, b) => b.items.length - a.items.length);
---

<Base
  title="Page Not Found — Central Florida Restaurants"
  description="That page could not be found. Browse Central Florida restaurants by county or return to the homepage."
  robots="noindex, follow"
>
  <main>
    <article>
      <h1>Page Not Found</h1>
      <p>
        Sorry, we couldn&rsquo;t find that page. It may have moved or never existed. Try one of the
        links below to find restaurants across Central Florida.
      </p>

      <section>
        <h2>Start here</h2>
        <ul class="link-list">
          <li><a href="/">Home — Central Florida Restaurants</a></li>
        </ul>
      </section>

      <section>
        <h2>Browse by county</h2>
        <ul class="link-list">
          {countyList.map((c) => (
            <li><a href={`/${c.slug}-county/`}>{c.name} County</a></li>
          ))}
        </ul>
      </section>
    </article>
  </main>
</Base>
