---
import FilterPageView from '../../../components/FilterPageView.astro';
import { filterPages } from '../../../lib/manifest.js';

// Dietary × district — /neighborhood/{district_slug}/{filter}/, driven by the manifest.
export function getStaticPaths() {
  return filterPages
    .filter((p) => p.geoType === 'district')
    .map((p) => {
      const segs = p.url.split('/').filter(Boolean); // ['neighborhood', district, filter]
      return { params: { district_slug: segs[1], filter: segs[2] }, props: { page: p } };
    });
}

const { page } = Astro.props;
---

<FilterPageView page={page} />
