---
import SpecialPageView from '../../components/SpecialPageView.astro';
import { specialPages } from '../../lib/manifest.js';

// /[city_slug]/hidden-gems/ — 4.5★+ with <200 reviews. Yields 0 pages in phase 1
// (hidden gems are low-review, mostly in later phases) but auto-builds then.
export function getStaticPaths() {
  return specialPages
    .filter((p) => p.specialType === 'hidden_gems')
    .map((p) => ({ params: { slug: p.geoSlug }, props: { page: p } }));
}

const { page } = Astro.props;
---

<SpecialPageView page={page} />
