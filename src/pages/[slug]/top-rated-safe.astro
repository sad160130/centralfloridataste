---
import SpecialPageView from '../../components/SpecialPageView.astro';
import { specialPages } from '../../lib/manifest.js';

// /[city_slug]/top-rated-safe/ — grade-A restaurants in the city.
export function getStaticPaths() {
  return specialPages
    .filter((p) => p.specialType === 'top_rated_safe')
    .map((p) => ({ params: { slug: p.geoSlug }, props: { page: p } }));
}

const { page } = Astro.props;
---

<SpecialPageView page={page} />
