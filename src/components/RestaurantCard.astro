---
import { titleCase, formatMonthYear } from '../lib/format.js';
import { photoInfo } from '../lib/photos.js';
import GradeBadge from './GradeBadge.astro';

const { r, showViolations = false } = Astro.props;
// Real storefront photo when we have one (lazy-loaded); else the monogram tile.
const photo = photoInfo(r.license_key);
const cuisine = r.cuisine ? titleCase(r.cuisine) : null;
const hasRating =
  Number.isFinite(r.rating) && Number.isFinite(r.reviews_count) && r.reviews_count > 0;

// Grade key drives the card's heatmap edge + tint. A–F are themed; anything
// else (NR / unrated) gets the neutral grey [data-grade="NR"] token set.
const gradeKey = ['A', 'B', 'C', 'D', 'F'].includes(String(r.health_grade).toUpperCase())
  ? String(r.health_grade).toUpperCase()
  : 'NR';

// Ghost watermark = first A–Z letter of the name ("#1 WOK", "(THE) DELI" → handled).
const letterMatch = String(r.name || '').match(/[A-Za-z]/);
const ghost = (letterMatch ? letterMatch[0] : String(r.name || '?')[0]).toUpperCase();

const DIET_SHORT = {
  vegan: 'Vegan', vegetarian: 'Veg', gluten_free: 'GF', dairy_free: 'DF',
  keto: 'Keto', paleo: 'Paleo', halal: 'Halal', kosher: 'Kosher',
  organic: 'Organic', healthy: 'Healthy', nut_aware: 'Nut-aware', pescatarian: 'Pesc.',
};
const diet = Array.isArray(r.dietary) ? r.dietary : [];
const dietShown = diet.slice(0, 2);
const dietMore = diet.length - dietShown.length;

const location = `${titleCase(r.city)}${r.county ? ` · ${r.county} County` : ''}`;
const inspected = formatMonthYear(r.latest_inspection_date);

const violationParts = [
  r.hp_violations ? `${r.hp_violations} high-priority` : null,
  r.intermediate_violations ? `${r.intermediate_violations} intermediate` : null,
  r.basic_violations ? `${r.basic_violations} basic` : null,
].filter(Boolean);
---
<li>
  <a class="card" data-grade={gradeKey} href={`${r.url}/`}>
    <div class={`card__head${photo ? ' has-photo' : ''}`}>
      {photo
        ? <img class="card__photo" src={photo.src} alt="" loading="lazy" decoding="async" width="800" height="500" />
        : <span class="card__ghost" aria-hidden="true">{ghost}</span>}
      <GradeBadge grade={r.health_grade} score={r.health_score} size="md" />
      {r.hidden_gem && (
        <span class="card__gem"><span class="star" aria-hidden="true">★</span> Hidden gem</span>
      )}
    </div>
    <div class="card__body">
      <span class="card__name">{r.name}</span>
      {(cuisine || hasRating) && (
        <span class="card__meta">
          {cuisine && <span class="chip chip--cuisine">{cuisine}</span>}
          {hasRating && (
            <span class="card__rating"><span class="star" aria-hidden="true">★</span> {r.rating}</span>
          )}
          {hasRating && <span class="card__count">({r.reviews_count})</span>}
        </span>
      )}
      <span class="card__loc">{location}</span>
      {dietShown.length > 0 && (
        <span class="card__diet">
          {dietShown.map((d) => <span class="chip">{DIET_SHORT[d] || d}</span>)}
          {dietMore > 0 && <span class="chip chip--more">+{dietMore} more</span>}
        </span>
      )}
      {showViolations && r.health_grade && (
        <span class="card__viol">
          Violations: {violationParts.length ? violationParts.join(', ') : 'none recorded'}
        </span>
      )}
      {inspected && <span class="card__date">Inspected {inspected}</span>}
    </div>
  </a>
</li>
